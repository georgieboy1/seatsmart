# Supabase — get these from your project's API settings page
# https://supabase.com/dashboard/project/_/settings/api

# Public — safe to expose to the browser. Used by the Supabase client in
# React components and server components.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses Row Level Security. NEVER expose to the browser
# and NEVER commit. Only use in route handlers and server actions where
# you've already authenticated the user yourself.
SUPABASE_SERVICE_ROLE_KEY=
